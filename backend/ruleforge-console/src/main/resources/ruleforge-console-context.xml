<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
    <import resource="classpath:ruleforge-core-context.xml"/>

    <bean id="ruleforge.consoleDebugWriter" class="com.ruleforge.console.servlet.console.ConsoleDebugWriter">
        <property name="debugMessageHolder" ref="ruleforge.debugMessageHolder"/>
    </bean>

    <bean id="ruleforge.debugMessageHolder" class="com.ruleforge.console.servlet.console.DebugMessageHolder"/>

    <bean id="ruleforge.httpSessionKnowledgeCache"
          class="com.ruleforge.console.servlet.respackage.HttpSessionKnowledgeCache"/>

    <bean id="ruleforge.permissionConfigServletHandler"
          class="com.ruleforge.console.servlet.permission.PermissionConfigServletHandler">
        <property name="repositoryService" ref="ruleforge.repositoryService"/>
        <property name="permissionStore" ref="ruleforge.permissionService"/>
    </bean>

    <bean id="ruleforge.permissionService" class="com.ruleforge.console.repository.permission.PermissionServiceImpl">
        <property name="repositoryService" ref="ruleforge.repositoryService"/>
    </bean>

    <bean id="ruleforge.decisionTableFileRefactor"
          class="com.ruleforge.console.repository.refactor.file.DecisionTableFileRefactor"/>
    <bean id="ruleforge.decisionTreeFileRefactor"
          class="com.ruleforge.console.repository.refactor.file.DecisionTreeFileRefactor"/>
    <bean id="ruleforge.flowFileRefactor" class="com.ruleforge.console.repository.refactor.file.FlowFileRefactor"/>
    <bean id="ruleforge.knowledgePackageFileRefactor"
          class="com.ruleforge.console.repository.refactor.file.KnowledgePackageFileRefactor"/>
    <bean id="ruleforge.rulesetFileRefactor" class="com.ruleforge.console.repository.refactor.file.RulesetFileRefactor"/>
    <bean id="ruleforge.scorecardFileRefactor"
          class="com.ruleforge.console.repository.refactor.file.ScorecardFileRefactor"/>
    <bean id="ruleforge.complexScorecardFileRefactor"
          class="com.ruleforge.console.repository.refactor.file.ComplexScorecardFileRefactor"/>
    <bean id="ruleforge.crossTableFileRefactor"
          class="com.ruleforge.console.repository.refactor.file.CrossTableFileRefactor"/>

    <bean id="ruleforge.decisionTableContentRefactor"
          class="com.ruleforge.console.repository.refactor.field.DecisionTableContentRefactor"/>
    <bean id="ruleforge.decisionTreeContentRefactor"
          class="com.ruleforge.console.repository.refactor.field.DecisionTreeContentRefactor"/>
    <bean id="ruleforge.flowContentRefactor" class="com.ruleforge.console.repository.refactor.field.FlowContentRefactor"/>
    <bean id="ruleforge.rulesetContentRefactor"
          class="com.ruleforge.console.repository.refactor.field.RulesetContentRefactor"/>
    <bean id="ruleforge.scorecardContentRefactor"
          class="com.ruleforge.console.repository.refactor.field.ScorecardContentRefactor"/>
    <bean id="ruleforge.complexScorecardContentRefactor"
          class="com.ruleforge.console.repository.refactor.field.ComplexScorecardContentRefactor"/>
    <bean id="ruleforge.scriptRulesetContentRefactor"
          class="com.ruleforge.console.repository.refactor.field.ScriptRulesetContentRefactor"/>
    <bean id="ruleforge.crossTableContentRefactor"
          class="com.ruleforge.console.repository.refactor.field.CrossTableContentRefactor"/>

    <bean id="ruleforge.resourceLoaderServletHandler" class="com.ruleforge.console.servlet.ResourceLoaderServletHandler"/>

    <bean id="ruleforge.loadKnowledgeServletHandler"
          class="com.ruleforge.console.servlet.knowledge.LoadKnowledgeServletHandler">
    </bean>

    <bean id="ruleforge.packageServletHandler" class="com.ruleforge.console.servlet.respackage.PackageServletHandler">
        <property name="repositoryService" ref="ruleforge.repositoryService"/>
        <property name="knowledgeBuilder" ref="ruleforge.knowledgeBuilder"/>
        <property name="httpSessionKnowledgeCache" ref="ruleforge.httpSessionKnowledgeCache"/>
    </bean>

    <bean id="ruleforge.reteDiagramServletHandler"
          class="com.ruleforge.console.servlet.diagram.ReteDiagramServletHandler">
        <property name="knowledgeBuilder" ref="ruleforge.knowledgeBuilder"/>
        <property name="httpSessionKnowledgeCache" ref="ruleforge.httpSessionKnowledgeCache"/>
    </bean>

    <bean id="ruleforge.variableEditorServletHandler"
          class="com.ruleforge.console.servlet.variable.VariableEditorServletHandler"/>
    <bean id="ruleforge.actionServletHandler" class="com.ruleforge.console.servlet.action.ActionServletHandler"/>
    <bean id="ruleforge.ruleFlowDesignerServletHandler"
          class="com.ruleforge.console.servlet.flow.RuleFlowDesignerServletHandler">
        <property name="repositoryService" ref="ruleforge.repositoryService"/>
    </bean>

    <bean id="ruleforge.commonServletHandler" class="com.ruleforge.console.servlet.common.CommonServletHandler"/>
    <bean id="ruleforge.clientConfigServletHandler"
          class="com.ruleforge.console.servlet.client.ClientConfigServletHandler">
        <property name="repositoryService" ref="ruleforge.repositoryService"/>
    </bean>

    <bean id="ruleforge.console.propertyPlaceholderConfigurer"
          class="org.springframework.beans.factory.config.PropertyPlaceholderConfigurer">
        <property name="ignoreUnresolvablePlaceholders" value="true"/>
        <property name="location">
            <value>classpath:ruleforge-console-context.properties</value>
        </property>
    </bean>

    <bean id="ruleforge.repositoryService" class="com.ruleforge.console.repository.RepositoryServiceImpl">
        <!--        <property name="repositoryBuilder" ref="ruleforge.repositoryBuilder"/>-->
        <!--<property name="permissionService" ref="ruleforge.permissionService"/>-->
    </bean>

</beans>